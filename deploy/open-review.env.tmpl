# Open Review -- EnvironmentFile template
# Rendered by install.sh; stored at /etc/open-review/open-review.env (0600)
# Do not add keys not consumed by the app -- the env-contract guard (DEPL-03) will fail.

# Infra secrets (installer-owned, generated once on first install, never rotated on upgrade)
OPEN_REVIEW_SECRET_KEY=__SECRET_KEY__
OPEN_REVIEW_SESSION_SECRET=__SESSION_SECRET__
OPEN_REVIEW_WEBHOOK_SECRET=__WEBHOOK_SECRET__

# Boot-only fields
OPEN_REVIEW_PORT=3000
OPEN_REVIEW_HOST=127.0.0.1
OPEN_REVIEW_DB_PATH=/opt/open-review/data/open-review.db
OPEN_REVIEW_LOG_LEVEL=info

# Optional operator credentials (uncomment and fill in for unattended install,
# or leave commented and enter them via the dashboard setup flow after first boot).
# CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=
# OPEN_REVIEW_REPOS=
# OPEN_REVIEW_DOMAIN=
# OPEN_REVIEW_PROVIDER=
