<!DOCTYPE html>
<html lang="en" data-theme="<%= it.theme ?? 'dark' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= it.title ?? 'Open Review' %></title>

  <!-- FOUC guard: synchronous, runs BEFORE the stylesheet link -->
  <script>(function(){try{var m=document.cookie.match(/(?:^|;\s*)or_theme=(dark|light)/);var t=m?m[1]:(window.matchMedia&&window.matchMedia('(prefers-color-scheme:dark)').matches?'dark':'light');document.documentElement.setAttribute('data-theme',t)}catch(e){}}());</script>

  <!-- Font preloads: crossorigin is required even for same-origin fonts -->
  <link rel="preload" href="/fonts/Geist-Variable.woff2" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="/fonts/GeistMono-Variable.woff2" as="font" type="font/woff2" crossorigin>

  <!-- External stylesheet replaces the inline style block -->
  <link rel="stylesheet" href="/styles/dashboard.css?v=<%= it.cssVersion ?? 'dev' %>">
</head>
<body x-data>
  <%~ it.body %>
  <script src="/vendor/htmx.min.js" defer></script>
  <script src="/vendor/alpine.min.js" defer></script>
</body>
</html>
