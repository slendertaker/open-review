<section id="secrets-section" style="border-top: 1px solid var(--color-hairline); padding-top: var(--spacing-xxl); margin-bottom: var(--spacing-section);">
  <div class="section-header">
    <span class="bracket-prefix">[+]</span>
    <h2 class="heading-md">Advanced -- manual GitHub setup</h2>
  </div>
  <p class="caption-md" style="color: var(--color-mute); margin-bottom: var(--spacing-md);">Use these fields if you created your GitHub App manually outside of the connect flow above. The GitHub section above is the recommended path for new installs.</p>

  <form
    hx-post="/dashboard/settings/secrets"
    hx-target="#secrets-section"
    hx-swap="outerHTML"
    style="max-width: 560px;"
  >
    <input type="hidden" name="_csrf" value="<%= it.csrfToken %>">

    <!-- Webhook secret -->
    <div class="field-row" style="margin-bottom: var(--spacing-md);">
      <label for="webhookSecret" class="body-md" style="display: block; margin-bottom: var(--spacing-xs);">Webhook secret</label>
      <p class="caption-md" style="color: var(--color-mute); margin: 0 0 var(--spacing-xs) 0;">The secret configured on your GitHub webhook. Used to verify incoming events.</p>
      <% if (it.webhookSecretPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-xs) 0;" aria-label="Masked preview of stored webhook secret"><%= it.webhookSecretPreview %></p>
      <% } else if (it.hasWebhookSecret) { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="webhookSecret"
        name="webhookSecret"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-mute); margin: var(--spacing-xs) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- Claude OAuth token -->
    <div class="field-row" style="margin-bottom: var(--spacing-md);">
      <label for="claudeOauthToken" class="body-md" style="display: block; margin-bottom: var(--spacing-xs);">Claude OAuth token</label>
      <p class="caption-md" style="color: var(--color-mute); margin: 0 0 var(--spacing-xs) 0;">Primary authentication for Claude Code. Run <code>claude setup-token</code> to generate.</p>
      <% if (it.claudeOauthPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-xs) 0;" aria-label="Masked preview of stored Claude OAuth token"><%= it.claudeOauthPreview %></p>
      <% } else if (it.hasClaudeOauthToken) { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="claudeOauthToken"
        name="claudeOauthToken"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-mute); margin: var(--spacing-xs) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- Anthropic API key -->
    <div class="field-row" style="margin-bottom: var(--spacing-md);">
      <label for="anthropicApiKey" class="body-md" style="display: block; margin-bottom: var(--spacing-xs);">Anthropic API key</label>
      <p class="caption-md" style="color: var(--color-mute); margin: 0 0 var(--spacing-xs) 0;">Fallback API key. Takes priority over OAuth token if set.</p>
      <% if (it.anthropicApiKeyPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-xs) 0;" aria-label="Masked preview of stored Anthropic API key"><%= it.anthropicApiKeyPreview %></p>
      <% } else if (it.hasAnthropicApiKey) { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="anthropicApiKey"
        name="anthropicApiKey"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-mute); margin: var(--spacing-xs) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- GitHub App ID -->
    <div class="field-row" style="margin-bottom: var(--spacing-md);">
      <label for="githubAppId" class="body-md" style="display: block; margin-bottom: var(--spacing-xs);">GitHub App ID</label>
      <p class="caption-md" style="color: var(--color-mute); margin: 0 0 var(--spacing-xs) 0;">Your GitHub App's numeric identifier.</p>
      <% if (it.githubAppIdPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-xs) 0;" aria-label="Masked preview of stored GitHub App ID"><%= it.githubAppIdPreview %></p>
      <% } else if (it.hasGithubAppId) { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="githubAppId"
        name="githubAppId"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-mute); margin: var(--spacing-xs) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- GitHub App private key -->
    <div class="field-row" style="margin-bottom: var(--spacing-md);">
      <label for="githubAppPrivateKey" class="body-md" style="display: block; margin-bottom: var(--spacing-xs);">GitHub App private key</label>
      <p class="caption-md" style="color: var(--color-mute); margin: 0 0 var(--spacing-xs) 0;">PEM-encoded private key for your GitHub App. Paste the full contents.</p>
      <% if (it.hasPrivateKey || it.hasGithubAppPrivateKey) { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(PEM key set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(not set)</p>
      <% } %>
      <textarea
        id="githubAppPrivateKey"
        name="githubAppPrivateKey"
        class="text-input"
        rows="6"
        placeholder="-----BEGIN RSA PRIVATE KEY-----"
        autocomplete="off"
        style="width: 100%; resize: vertical;"
      ></textarea>
      <p class="caption-md" style="color: var(--color-mute); margin: var(--spacing-xs) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- Personal Access Token -->
    <div class="field-row" style="margin-bottom: var(--spacing-md);">
      <label for="githubToken" class="body-md" style="display: block; margin-bottom: var(--spacing-xs);">Personal Access Token</label>
      <p class="caption-md" style="color: var(--color-mute); margin: 0 0 var(--spacing-xs) 0;">Fallback for single-repo installs without a GitHub App. Requires <code>repo</code> and <code>pull_requests</code> scopes.</p>
      <% if (it.githubTokenPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-xs) 0;" aria-label="Masked preview of stored Personal Access Token"><%= it.githubTokenPreview %></p>
      <% } else if (it.hasGithubToken) { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-ash); margin: 0 0 var(--spacing-xs) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="githubToken"
        name="githubToken"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-mute); margin: var(--spacing-xs) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- Save button + flash region -->
    <div style="margin-top: var(--spacing-md); display: flex; align-items: center; gap: var(--spacing-md);">
      <button type="submit" class="btn-secondary">[ save ]</button>
    </div>

    <% if (it.flash) { %>
    <%~ it.flash %>
    <% } %>
  </form>
</section>
