<section id="secrets-section" class="section-card">
  <div class="section-header">
    <span class="bracket-prefix" style="display:inline-flex;align-items:center;"><%~ include('./icons', { name: 'check' }) %></span>
    <h2 class="heading-md">Provider secrets</h2>
  </div>
  <p class="caption-md" style="color: var(--color-text-muted); margin-bottom: var(--spacing-3);">Credentials for the Claude review provider. GitHub credentials are managed entirely through the GitHub connect flow.</p>

  <form
    hx-post="/dashboard/settings/secrets"
    hx-target="#content"
    hx-swap="innerHTML"
    style="max-width: 560px;"
  >
    <input type="hidden" name="_csrf" value="<%= it.csrfToken %>">

    <!-- Claude OAuth token -->
    <div class="field-row" style="margin-bottom: var(--spacing-3);">
      <label for="claudeOauthToken" class="body-md" style="display: block; margin-bottom: var(--spacing-1);">Claude OAuth token</label>
      <p class="caption-md" style="color: var(--color-text-muted); margin: 0 0 var(--spacing-1) 0;">Primary authentication for Claude Code. Run <code>claude setup-token</code> to generate.</p>
      <% if (it.claudeOauthPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-1) 0;" aria-label="Masked preview of stored Claude OAuth token"><%= it.claudeOauthPreview %></p>
      <% } else if (it.hasClaudeOauthToken) { %>
      <p class="caption-md" style="color: var(--color-text-disabled); margin: 0 0 var(--spacing-1) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-text-disabled); margin: 0 0 var(--spacing-1) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="claudeOauthToken"
        name="claudeOauthToken"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-text-muted); margin: var(--spacing-1) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- Anthropic API key -->
    <div class="field-row" style="margin-bottom: var(--spacing-3);">
      <label for="anthropicApiKey" class="body-md" style="display: block; margin-bottom: var(--spacing-1);">Anthropic API key</label>
      <p class="caption-md" style="color: var(--color-text-muted); margin: 0 0 var(--spacing-1) 0;">Fallback API key. Takes priority over OAuth token if set.</p>
      <% if (it.anthropicApiKeyPreview) { %>
      <p class="caption-md secret-preview" style="margin: 0 0 var(--spacing-1) 0;" aria-label="Masked preview of stored Anthropic API key"><%= it.anthropicApiKeyPreview %></p>
      <% } else if (it.hasAnthropicApiKey) { %>
      <p class="caption-md" style="color: var(--color-text-disabled); margin: 0 0 var(--spacing-1) 0;">(set)</p>
      <% } else { %>
      <p class="caption-md" style="color: var(--color-text-disabled); margin: 0 0 var(--spacing-1) 0;">(not set)</p>
      <% } %>
      <input
        type="password"
        id="anthropicApiKey"
        name="anthropicApiKey"
        class="text-input"
        placeholder="Enter new value to update"
        autocomplete="off"
        style="width: 100%;"
      >
      <p class="caption-md" style="color: var(--color-text-muted); margin: var(--spacing-1) 0 0 0;">Leave blank to keep the current value.</p>
    </div>

    <!-- Save button + flash region -->
    <div style="margin-top: var(--spacing-3); display: flex; align-items: center; gap: var(--spacing-3);">
      <button type="submit" class="btn btn-secondary">Save</button>
    </div>

    <% if (it.flash) { %>
    <%~ it.flash %>
    <% } %>
  </form>
</section>
