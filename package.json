{
  "name": "open-review",
  "version": "0.1.0",
  "description": "Self-hosted GitHub PR reviewer using Claude Code and other AI agents",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:dev": "NODE_OPTIONS=--max-old-space-size=384 tsx src/index.ts",
    "build": "tsc -p tsconfig.json && cp src/state/schema.sql dist/src/state/schema.sql",
    "start": "NODE_OPTIONS=--max-old-space-size=384 node dist/src/index.js",
    "test": "vitest run",
    "test:dot": "vitest run --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": ">=2.1.163",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks": "^14.2.0",
    "@octokit/webhooks-types": "^7.6.1",
    "better-sqlite3": "^12.11.1",
    "fastify": "^5.8.5",
    "nanoid": "^5.0.0",
    "p-limit": "^6.2.0",
    "parse-diff": "^0.12.0",
    "picomatch": "^4.0.4",
    "pino": "^9.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/picomatch": "^4.0.3",
    "tsx": "latest",
    "typescript": "^5.8.0",
    "vitest": "^4.1.9"
  }
}
